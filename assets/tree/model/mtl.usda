                color3f inputs:diffuseColor = (0.477, 0.773, 0.137)
                color3f inputs:emissiveColor = (0.047400635, 0.076212496, 0.01316644)
                float inputs:roughness = 0.7
                color3f inputs:specularColor = (1, 1, 1)
                token outputs:surface
            }
