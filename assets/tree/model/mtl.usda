    }

    over "geo" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding:preview = </__root/mtl/usdpreviewmaterial>

        over "trunk" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding:full = </__root/mtl/trunk_mtlx>
        }

        over "leavesBig" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding:full = </__root/mtl/leaves_a_mtlx>
        }

        over "leavesSmall" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding:full = </__root/mtl/leaves_b_mtlx>
        }

        over "leaves" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </__root/mtl/leaves_c_mtlx>
        }
    }
}

