            prepend inherits = </__class_mtl__/leaves_b_mtlx>
        )
        {
            token outputs:mtlx:surface.connect = </__root/mtl/leaves_b_mtlx/mtlxstandard_surface.outputs:out>
            token outputs:surface.connect = </__root/mtl/leaves_b_mtlx/mtlxstandard_preview.outputs:surface>

