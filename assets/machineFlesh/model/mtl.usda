            def Shader "mtlxmultiply1"
            {
                uniform token info:id = "ND_multiply_vector3FA"
                vector3f inputs:in1.connect = </__root/mtl/smoke_mtlx/mtlxconvert1.outputs:out>
                float inputs:in2.connect = </__root/mtl/smoke_mtlx/mtlxpower1.outputs:out>
                vector3f outputs:out
            }

            def Shader "mtlxconvert1"
            {
                uniform token info:id = "ND_convert_color3_vector3"
                color3f inputs:in.connect = </__root/mtl/smoke_mtlx/mtlxconstant1.outputs:out>
                vector3f outputs:out
            }

            def Shader "mtlxconstant1"
            {
                uniform token info:id = "ND_constant_color3"
                color3f inputs:value = (0.65, 0.6, 0.3)
                color3f outputs:out
            }

            def Shader "mtlxpower1"
            {
                uniform token info:id = "ND_power_float"
                float inputs:in1.connect = </__root/mtl/smoke_mtlx/vol_density.outputs:out>
                float inputs:in2 = 0.65
                float outputs:out
            }

            def Shader "vol_density"
            {
                uniform token info:id = "ND_geompropvalue_float"
                float inputs:default = 6.22
                string inputs:geomprop = "density"
                float outputs:out
            }

            def Shader "mtlxmultiply2"
            {
                uniform token info:id = "ND_multiply_vector3FA"
                vector3f inputs:in1.connect = </__root/mtl/smoke_mtlx/mtlxconvert1.outputs:out>
                float inputs:in2.connect = </__root/mtl/smoke_mtlx/mtlxpower1.outputs:out>
                vector3f outputs:out
            }
        }
    }

    over "geo"
    {
        over "Flesh_GRP"
        {
            over "CowBody" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                rel material:binding:full = </__root/mtl/mf_mtlx>
                rel material:binding:preview = </__root/mtl/usdpreviewmaterial>
            }

            over "CowEye_l"
            {
                over "eyeball" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/eye_mtlx>
                }

                over "cornea" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/cornea_mtlx>
                }
            }

            over "CowEye_r"
            {
                over "eyeball" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/eye_mtlx>
                }

                over "cornea" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/cornea_mtlx>
                }
            }
        }

        over "Machine_GRP" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding:full = </__root/mtl/mf_mtlx>
            rel material:binding:preview = </__root/mtl/usdpreviewmaterial>
        }
    }

    over "vol" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        rel material:binding = </__root/mtl/smoke_mtlx>
    }

    over "crv" (
        prepend apiSchemas = ["MaterialBindingAPI"]
