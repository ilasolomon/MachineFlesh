        def Material "furTest_karma" (
            prepend apiSchemas = ["MaterialXConfigAPI"]
            prepend inherits = </__class_mtl__/furTest_karma>
        )
        {
            string config:mtlx:version = "1.39"
            token outputs:kma:displacement.connect = </__root/mtl/furTest_karma/mtlxdisplacement.outputs:out>
            token outputs:kma:surface.connect = </__root/mtl/furTest_karma/kma_fur1.outputs:surface>

            def Shader "kma_fur1"
            {
                uniform token info:id = "kma_fur_2"
                color3f inputs:baseColor.connect = </__root/mtl/furTest_karma/mtlximage1.outputs:out>
                float inputs:melanin = 0.5
                float inputs:melaninRandomize = 0.2
                float inputs:melaninRedness = 0.25
                float inputs:thicknessScale = 0.5
                color3f inputs:tint.connect = </__root/mtl/furTest_karma/mtlximage1.outputs:out>
                token outputs:surface
