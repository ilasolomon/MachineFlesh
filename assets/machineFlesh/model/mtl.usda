        )
        {
            token outputs:kma:volume.connect = </__root/mtl/smoke_mtlx/mtlxvolume1.outputs:out>

            def Shader "mtlxvolume1"
            {
                uniform token info:id = "ND_volume"
                string inputs:vdf.connect = </__root/mtl/smoke_mtlx/mtlxanisotropic_vdf1.outputs:out>
