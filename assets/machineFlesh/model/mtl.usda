                float2 outputs:result
            }

            def Shader "mtlxstandard_preview_texture_diffuseColor" (
                customData = {
                    bool HoudiniIsAutoCreatedShader = 1
                }
            )
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./components/tex/1k/exr/color_<UDIM>.exr@
                float2 inputs:st.connect = </__root/mtl/mf_mtlx/mtlxstandard_preview_uv.outputs:result>
                color3f outputs:rgb
            }
        }

