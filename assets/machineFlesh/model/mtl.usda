                color3f inputs:diffuseColor.connect = </__root/mtl/fur_mtlx/mtlxstandard_preview_texture_diffuseColor.outputs:rgb>
                float inputs:roughness = 0.45
                color3f inputs:specularColor = (1, 1, 1)
