            }
        }

        def Material "smoke_mtlx" (
            prepend apiSchemas = ["MaterialXConfigAPI"]
            prepend inherits = </__class_mtl__/smoke_mtlx>
        )
        {
            string config:mtlx:version = "1.39"
            token outputs:mtlx:volume.connect = </__root/mtl/smoke_mtlx/mtlxvolume1.outputs:out>

            def Shader "mtlxvolume1"
            {
                uniform token info:id = "ND_volume"
                string inputs:vdf.connect = </__root/mtl/smoke_mtlx/mtlxanisotropic_vdf1.outputs:out>
                token outputs:out
            }

            def Shader "mtlxanisotropic_vdf1"
            {
                uniform token info:id = "ND_anisotropic_vdf"
                vector3f inputs:absorption.connect = </__root/mtl/smoke_mtlx/mtlxmultiply1.outputs:out>
                float inputs:anisotropy.connect = </__root/mtl/smoke_mtlx/vol_density.outputs:out>
                vector3f inputs:scattering.connect = </__root/mtl/smoke_mtlx/mtlxmultiply2.outputs:out>
                token outputs:out
            }

            def Shader "mtlxmultiply1"
            {
                uniform token info:id = "ND_multiply_color3FA"
                color3f inputs:in1.connect = </__root/mtl/smoke_mtlx/mtlxconstant1.outputs:out>
                float inputs:in2.connect = </__root/mtl/smoke_mtlx/mtlxpower1.outputs:out>
                color3f outputs:out
            }

            def Shader "mtlxconstant1"
            {
                uniform token info:id = "ND_constant_color3"
                color3f inputs:value = (0.6, 0.5, 0.3)
                color3f outputs:out
            }

            def Shader "mtlxpower1"
            {
                uniform token info:id = "ND_power_float"
                float inputs:in1.connect = </__root/mtl/smoke_mtlx/vol_density.outputs:out>
                float inputs:in2 = 0.8
                float outputs:out
            }

            def Shader "vol_density"
            {
                uniform token info:id = "ND_geompropvalue_float"
                string inputs:geomprop = "density"
                float outputs:out
            }

            def Shader "mtlxmultiply2"
            {
                uniform token info:id = "ND_multiply_color3FA"
                color3f inputs:in1.connect = </__root/mtl/smoke_mtlx/mtlxconstant2.outputs:out>
                float inputs:in2.connect = </__root/mtl/smoke_mtlx/mtlxpower1.outputs:out>
                color3f outputs:out
            }

            def Shader "mtlxconstant2"
            {
                uniform token info:id = "ND_constant_color3"
                color3f inputs:value = (0.6, 0.5, 0.3)
                color3f outputs:out
            }
        }
    }

    over "geo"
    {
        over "Flesh_GRP"
        {
            over "CowBody" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                rel material:binding:full = </__root/mtl/mf_mtlx>
                rel material:binding:preview = </__root/mtl/usdpreviewmaterial>
            }

            over "CowEye_l"
            {
                over "eyeball" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/eye_mtlx>
                }

                over "cornea" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/cornea_mtlx>
                }
            }

            over "CowEye_r"
            {
                over "eyeball" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/eye_mtlx>
                }

                over "cornea" (
                    prepend apiSchemas = ["MaterialBindingAPI"]
                )
                {
                    rel material:binding = </__root/mtl/cornea_mtlx>
                }
            }
        }

        over "Machine_GRP" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding:full = </__root/mtl/mf_mtlx>
            rel material:binding:preview = </__root/mtl/usdpreviewmaterial>
        }
    }

    over "vol"
    {
        over "volume_0" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
