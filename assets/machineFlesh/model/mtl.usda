                asset inputs:file = @./components/tex/1k/png/color_<UDIM>.png@ (
                    colorSpace = "Raw"
                )
                float2 inputs:texcoord.connect = </__root/mtl/fur_mtlx/mtlxtexcoord1.outputs:out>
                color3f outputs:out
            }

