                bool driver:parameters:aov:husk:multiSampled = 0
                string driver:parameters:aov:husk:name = "N"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "ray:hitN"
                uniform token sourceType = "raw"
            }

            def RenderVar "albedo" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "color3f"
                string driver:parameters:aov:husk:channel_prefix = "albedo"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "color3h"
                bool driver:parameters:aov:husk:multiSampled = 1
                string driver:parameters:aov:husk:name = "albedo"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "CDA"
                uniform token sourceType = "lpe"
            }

            def RenderVar "ambientocclusion" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "color3f"
                string driver:parameters:aov:husk:channel_prefix = "ao"
