            }

            def RenderVar "combinedvolume" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "color3f"
                string driver:parameters:aov:husk:channel_prefix = "combinedvolume"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "color3h"
                bool driver:parameters:aov:husk:multiSampled = 1
                string driver:parameters:aov:husk:name = "combinedvolume"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "CV.*L"
                uniform token sourceType = "lpe"
            }

            def RenderVar "coat" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "color3f"
                string driver:parameters:aov:husk:channel_prefix = "coat"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "color3h"
                bool driver:parameters:aov:husk:multiSampled = 1
                string driver:parameters:aov:husk:name = "coat"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "C<...'coat'>.*L"
                uniform token sourceType = "lpe"
            }

            def RenderVar "sss" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "color3f"
                string driver:parameters:aov:husk:channel_prefix = "sss"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "color3h"
                bool driver:parameters:aov:husk:multiSampled = 1
                string driver:parameters:aov:husk:name = "sss"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "C<TD>.*L"
                uniform token sourceType = "lpe"
            }

            def RenderVar "hitP" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "point3f"
                string driver:parameters:aov:husk:channel_prefix = "P"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "float3"
                bool driver:parameters:aov:husk:multiSampled = 0
                string driver:parameters:aov:husk:name = "P"
                string driver:parameters:aov:karma:filter = '["ubox",{}]'
                uniform string sourceName = "ray:hitP"
                uniform token sourceType = "raw"
            }

            def RenderVar "hitP_camera" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "point3f"
                string driver:parameters:aov:husk:channel_prefix = "P_camera"
                float driver:parameters:aov:husk:clearValue = 0
                token driver:parameters:aov:husk:format = "float3"
