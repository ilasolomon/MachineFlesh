                token driver:parameters:aov:husk:format = "float"
                bool driver:parameters:aov:husk:multiSampled = 0
                string driver:parameters:aov:husk:name = "depth"
                string driver:parameters:aov:karma:filter = '["minmax",{"mode":"zmin"}]'
                uniform string sourceName = "ray:hitPz"
                uniform token sourceType = "raw"
            }

            def RenderVar "hitN" (
                prepend apiSchemas = ["KarmaRenderVarAPI", "HuskRenderVarAPI"]
            )
            {
                uniform token dataType = "normal3f"
                string driver:parameters:aov:husk:channel_prefix = "N"
